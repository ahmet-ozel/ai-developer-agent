# ============================================================
# AI Developer Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Jira Cloud ---
JIRA_URL=https://your-site.atlassian.net
JIRA_USERNAME=your.email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_WEBHOOK_SECRET=any-random-string
JIRA_BOT_USERNAME=ai-developer-bot
JIRA_TRANSITION_IN_PROGRESS=
JIRA_TRANSITION_IN_REVIEW=

# --- Git Provider: github | gitlab | bitbucket ---
GIT_PROVIDER=github
GIT_BASE_BRANCH=main

# --- GitHub (if GIT_PROVIDER=github) ---
GITHUB_TOKEN=ghp_your_github_token
GITHUB_OWNER=your-github-username

# --- GitLab (if GIT_PROVIDER=gitlab) ---
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-your_gitlab_token
GITLAB_GROUP=your-gitlab-group

# --- Bitbucket (if GIT_PROVIDER=bitbucket) ---
# NOTE: Bitbucket app passwords deprecated Sep 2025. Use Atlassian API tokens instead.
# BITBUCKET_USERNAME should be your Atlassian account email.
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_USERNAME=your-email@example.com
BITBUCKET_APP_PASSWORD=your-atlassian-api-token
BITBUCKET_API_TOKEN=

# --- LLM Fast Tier ---
LLM_FAST_PROVIDER=openai
LLM_FAST_MODEL=gpt-4o-mini
LLM_FAST_API_KEY=sk-your-openai-key
LLM_FAST_ENDPOINT=

# --- LLM Strong Tier ---
LLM_STRONG_PROVIDER=openai
LLM_STRONG_MODEL=gpt-4o
LLM_STRONG_API_KEY=sk-your-openai-key
LLM_STRONG_ENDPOINT=
LLM_FALLBACK_CHAIN=[]

# --- Trigger Mode: polling | webhook ---
TRIGGER_MODE=polling
POLL_INTERVAL_SECONDS=30
JIRA_PROJECT_KEY=

# --- Pipeline ---
MAX_REVIEW_RETRIES=2
MAX_FILES_PER_TASK=10
MAX_FILE_CHANGES=15
MAX_CONTEXT_TOKENS=100000
MAX_FILE_SIZE_KB=100
BRANCH_PATTERN=feature/{issue_key}-ai
AUTO_CREATE_PR=true
PR_AUTO_ASSIGN_REVIEWER=false
DRY_RUN=true

# --- PR Review ---
PR_REVIEWER=
PR_DRAFT_MODE=true
PR_AUTO_MERGE=false

# --- Confluence ---
CONFLUENCE_ENABLED=false
CONFLUENCE_URL=
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=
CONFLUENCE_PARENT_PAGE_ID=

# --- Task Filtering ---
SKIP_TASK_TYPES=[]
ALLOWED_TASK_TYPES=[]

# --- LLM Tier Overrides ---
TASK_READER_LLM_TIER=fast
CODE_FINDER_LLM_TIER=fast
CODE_WRITER_LLM_TIER=strong
CODE_REVIEWER_LLM_TIER=strong
